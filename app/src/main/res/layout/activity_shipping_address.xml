<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg"
    tools:context="fpoly.DatnMD06Su26.trendify.activity.ShippingAddressActivity">

    <!-- Top AppBar / Toolbar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/trend_bg"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/trend_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Sổ địa chỉ"
            android:textColor="@color/trend_text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <!-- Thin bottom border line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#10000000"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <!-- Scrollable Content Canvas -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Editorial Header Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN GIAO HÀNG"
                android:textColor="@color/trend_muted"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chọn địa chỉ giao hàng"
                android:textColor="@color/trend_text"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đảm bảo thông tin giao hàng chính xác để trải nghiệm mua sắm tại Trendify luôn được hoàn hảo và nhanh chóng nhất."
                android:textColor="@color/trend_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="5dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp" />

            <!-- List Header action line -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="DANH SÁCH ĐÃ LƯU"
                    android:textColor="@color/trend_text"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium" />

                <!-- Text-button styled btnAddAddress -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddAddress"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="THÊM MỚI"
                    android:textColor="@color/trend_text"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_plus"
                    app:iconSize="16dp"
                    app:iconTint="@color/trend_text" />
            </RelativeLayout>

            <!-- Empty State Address Message -->
            <TextView
                android:id="@+id/tvEmptyAddresses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:paddingVertical="32dp"
                android:text="Chưa có địa chỉ giao hàng nào được lưu. Vui lòng thêm địa chỉ mới."
                android:textColor="@color/trend_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Dynamic Address Container -->
            <LinearLayout
                android:id="@+id/addressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/trend_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <!-- Top separator line inside panel -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#10000000"
                android:layout_marginBottom="16dp" />

            <!-- Continue Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="TIẾP TỤC"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                app:backgroundTint="@color/black"
                app:cornerRadius="2dp"
                app:icon="@drawable/ic_chevron_right"
                app:iconGravity="end"
                app:iconSize="18dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>