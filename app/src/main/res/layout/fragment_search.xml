<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/trend_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu"
            android:layout_marginStart="20dp"
            app:tint="@color/trend_text"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRENDIFY"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/trend_text"
            android:letterSpacing="0.08"
            android:fontFamily="serif"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/ivSearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="16dp"
            app:tint="@color/trend_text"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivNotification" />

        <ImageView
            android:id="@+id/ivNotification"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_shopping_bag"
            android:layout_marginEnd="20dp"
            app:tint="@color/trend_text"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Search content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:paddingBottom="48dp">

            <!-- Search Input with underline -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_underline"
                android:hint="Bạn đang tìm kiếm sản phẩm gì?"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textSize="14sp"
                android:textColor="@color/trend_text"
                android:textColorHint="#999999"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Search Results Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:padding="4dp"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                app:layout_constraintTop_toBottomOf="@id/etSearch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- No Results state -->
            <TextView
                android:id="@+id/tvNoResults"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không tìm thấy kết quả phù hợp"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="40dp"
                android:fontFamily="serif"
                android:textStyle="italic"
                app:layout_constraintTop_toBottomOf="@id/etSearch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Static content (History + Trending) -->
            <LinearLayout
                android:id="@+id/llStaticContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/etSearch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Recent Searches Header -->
                <TextView
                    android:id="@+id/tvRecent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LỊCH SỬ TÌM KIẾM"
                    android:textColor="@color/trend_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="20dp" />

                <!-- Recent Searches list container -->
                <LinearLayout
                    android:id="@+id/llRecentSearches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />

                <!-- Trending Header -->
                <TextView
                    android:id="@+id/tvTrending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XU HƯỚNG MUA SẮM"
                    android:textColor="@color/trend_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="28dp" />

                <!-- Trending Chips with rectangular outline styling -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgTrending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Váy hè"
                        android:textColor="@color/trend_text"
                        app:chipBackgroundColor="@android:color/transparent"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/color_grey_bg"
                        app:cornerRadius="2dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giày thể thao"
                        android:textColor="@color/trend_text"
                        app:chipBackgroundColor="@android:color/transparent"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/color_grey_bg"
                        app:cornerRadius="2dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Túi xách"
                        android:textColor="@color/trend_text"
                        app:chipBackgroundColor="@android:color/transparent"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/color_grey_bg"
                        app:cornerRadius="2dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kính mát"
                        android:textColor="@color/trend_text"
                        app:chipBackgroundColor="@android:color/transparent"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/color_grey_bg"
                        app:cornerRadius="2dp" />

                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
