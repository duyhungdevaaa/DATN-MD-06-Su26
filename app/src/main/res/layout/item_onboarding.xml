<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg">

    <!-- Slide Illustration Image -->
    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintHeight_percent="0.55"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Gradient fade at bottom of image for soft transition -->
    <View
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_banner_gradient"
        android:rotation="180"
        app:layout_constraintBottom_toBottomOf="@id/ivIcon" />

    <!-- Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BỘ SƯU TẬP 2024"
            android:textColor="@color/trend_muted"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sự Sang Trọng Được Chọn Lọc"
            android:textColor="@color/trend_text"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khám phá những xu hướng thời trang mới nhất từ các nhà thiết kế lừng danh thế giới."
            android:textColor="@color/trend_muted"
            android:textSize="15sp"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
