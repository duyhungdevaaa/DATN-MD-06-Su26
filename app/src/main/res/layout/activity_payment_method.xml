<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg"
    tools:context="fpoly.DatnMD06Su26.trendify.activity.PaymentMethodActivity">

    <!-- Top AppBar / Toolbar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/trend_bg"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/trend_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Phương thức thanh toán"
            android:textColor="@color/trend_text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <!-- Thin bottom border line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#10000000"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <!-- Scrollable Content Canvas -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Title Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHƯƠNG THỨC THANH TOÁN"
                android:textColor="@color/trend_muted"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chọn phương thức"
                android:textColor="@color/trend_text"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

            <!-- 1. Credit/Debit Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCredit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconCredit"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_credit_card"
                        app:tint="@color/trend_text" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconCredit"
                        android:layout_toStartOf="@id/indicatorCredit"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THÈ TÍN DỤNG / GHI NỢ"
                            android:textColor="@color/trend_text"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visa, Mastercard, JCB, AMEX"
                            android:textColor="@color/trend_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/indicatorCredit"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_black" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Ví MoMo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMomo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconMomo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_credit_card"
                        app:tint="@color/trend_muted" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconMomo"
                        android:layout_toStartOf="@id/indicatorMomo"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VÍ MOMO"
                            android:textColor="@color/trend_text"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thanh toán nhanh qua ví điện tử"
                            android:textColor="@color/trend_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/indicatorMomo"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Chuyển khoản ngân hàng -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBankTransfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconBank"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_credit_card"
                        app:tint="@color/trend_muted" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconBank"
                        android:layout_toStartOf="@id/indicatorBank"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHUYỂN KHOẢN NGÂN HÀNG"
                            android:textColor="@color/trend_text"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thanh toán trực tiếp bằng mã QR"
                            android:textColor="@color/trend_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/indicatorBank"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. COD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconCod"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_local_shipping"
                        app:tint="@color/trend_muted" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconCod"
                        android:layout_toStartOf="@id/indicatorCod"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THANH TOÁN KHI NHẬN HÀNG (COD)"
                            android:textColor="@color/trend_text"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thanh toán bằng tiền mặt khi giao hàng"
                            android:textColor="@color/trend_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/indicatorCod"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Promo/Discount Code Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÃ GIẢM GIÁ"
                android:textColor="@color/trend_muted"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <!-- Apply button styled as Text/Outline Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyPromo"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="ÁP DỤNG"
                    android:textColor="@color/trend_text"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPromoCode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/btnApplyPromo"
                    android:background="@drawable/bg_input_underline"
                    android:hint="Nhập mã ưu đãi của bạn"
                    android:textColorHint="#CFC4C5"
                    android:textColor="@color/trend_text"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />
            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/trend_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <!-- Top separator line inside panel -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#10000000"
                android:layout_marginBottom="16dp" />

            <!-- Continue Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="XÁC NHẬN THANH TOÁN"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                app:backgroundTint="@color/black"
                app:cornerRadius="2dp"
                app:icon="@drawable/ic_chevron_right"
                app:iconGravity="end"
                app:iconSize="18dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
